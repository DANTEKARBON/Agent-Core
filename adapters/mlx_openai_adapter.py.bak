import requests
import json
import time
import logging
from typing import Dict, Any, Optional
from adapters.base_llm_adapter import BaseLLMAdapter
from core.contracts import LLMResponse

logger = logging.getLogger(__name__)

class MLXOpenAIAdapter(BaseLLMAdapter):
    def __init__(self, base_url: str, model_path: str = "default", max_tokens: int = 500, temperature: float = 0.7):
        self.base_url = base_url.rstrip('/')
        self.model_path = model_path
        self.max_tokens = max_tokens
        self.temperature = temperature

    def _estimate_tokens(self, text: str) -> int:
        return len(text) // 4

    def generate(self, prompt: str, **kwargs) -> Dict[str, Any]:
        url = f"{self.base_url}/v1/chat/completions"
        max_tokens = kwargs.get("max_tokens", self.max_tokens)
        temperature = kwargs.get("temperature", self.temperature)
        payload = {
            "model": self.model_path,
            "messages": [{"role": "user", "content": prompt}],
            "max_tokens": max_tokens,
            "temperature": temperature,
            "stream": True,   # Включаем потоковый режим для замера TTFT
            "stop": ["\n\n", "User:", "Пользователь:"],
        }
        start_time = time.time()
        ttft_ms = None
        full_text = ""
        input_tokens = 0
        output_tokens = 0
        
        try:
            response = requests.post(url, json=payload, timeout=60, stream=True)
            response.raise_for_status()
            
            # Потоковая обработка
            for line in response.iter_lines():
                if line:
                    line = line.decode('utf-8')
                    if line.startswith('data: '):
                        data_str = line[6:]
                        if data_str == '[DONE]':
                            break
                        try:
                            chunk = json.loads(data_str)
                            if ttft_ms is None:
                                ttft_ms = (time.time() - start_time) * 1000
                            if 'choices' in chunk and len(chunk['choices']) > 0:
                                delta = chunk['choices'][0].get('delta', {})
                                content = delta.get('content', '')
                                if content:
                                    full_text += content
                            # Попытка получить usage из последнего чанка (не у всех серверов есть)
                            if 'usage' in chunk:
                                usage = chunk['usage']
                                input_tokens = usage.get('prompt_tokens', 0)
                                output_tokens = usage.get('completion_tokens', 0)
                        except json.JSONDecodeError:
                            continue
            
            generation_time_ms = (time.time() - start_time) * 1000
            if ttft_ms is None:
                ttft_ms = generation_time_ms  # fallback
            
            # Если usage не пришёл, оцениваем
            if input_tokens == 0:
                input_tokens = self._estimate_tokens(prompt)
            if output_tokens == 0:
                output_tokens = self._estimate_tokens(full_text)
            
            return {
                "response": full_text,
                "metadata": {
                    "model": self.model_path,
                    "input_tokens": input_tokens,
                    "output_tokens": output_tokens,
                    "generation_time_ms": generation_time_ms,
                    "ttft_ms": ttft_ms,
                    "timestamp": start_time
                }
            }
        except requests.exceptions.Timeout:
            generation_time_ms = (time.time() - start_time) * 1000
            logger.error(f"Timeout connecting to {self.base_url}")
            return {
                "response": "[Ошибка: таймаут при обращении к модели]",
                "metadata": {
                    "model": self.model_path,
                    "input_tokens": 0,
                    "output_tokens": 0,
                    "generation_time_ms": generation_time_ms,
                    "ttft_ms": None,
                    "timestamp": start_time,
                    "error": "Timeout"
                }
            }
        except Exception as e:
            generation_time_ms = (time.time() - start_time) * 1000
            logger.exception(f"Unexpected error: {e}")
            return {
                "response": f"[Ошибка MLX адаптера: {e}]",
                "metadata": {
                    "model": self.model_path,
                    "input_tokens": 0,
                    "output_tokens": 0,
                    "generation_time_ms": generation_time_ms,
                    "ttft_ms": None,
                    "timestamp": start_time,
                    "error": str(e)
                }
            }

    def generate_contract(self, prompt: str, max_tokens: int = 5, temperature: float = 0.0) -> LLMResponse:
        """Метод для router_service, возвращает LLMResponse."""
        result = self.generate(prompt, max_tokens=max_tokens, temperature=temperature)
        text = result.get("response", "")
        metadata = result.get("metadata", {})
        error = metadata.get("error")
        status = "error" if error else "success"
        return LLMResponse(
            text=text.strip(),
            prompt_tokens=metadata.get("input_tokens", 0),
            completion_tokens=metadata.get("output_tokens", 0),
            total_tokens=metadata.get("input_tokens", 0) + metadata.get("output_tokens", 0),
            status=status,
            error=error
        )

    def load_model(self) -> bool:
        try:
            response = requests.get(f"{self.base_url}/v1/models", timeout=5)
            return response.status_code == 200
        except:
            return False

    def unload_model(self) -> bool:
        return True
